/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: SAMEORIGIN
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(self)

/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Videos: cache aggressively. Without this Cloudflare serves them
# max-age=0/must-revalidate, so a looping <video> re-downloads the whole file
# every loop and saturates the connection (stalls page navigation).
/videos/*
  Cache-Control: public, max-age=31536000, immutable
