# Sanity
SANITY_PROJECT_ID=
SANITY_DATASET=production
SANITY_API_VERSION=2026-03-01
SANITY_READ_TOKEN=
SANITY_WRITE_TOKEN=

# Studio
SANITY_STUDIO_PROJECT_ID=
SANITY_STUDIO_DATASET=production

# Public (browser-exposed)
PUBLIC_GA4_MEASUREMENT_ID=
PUBLIC_GOOGLE_MAPS_API_KEY=
PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Stripe (server-only secrets — set in Cloudflare Pages, never PUBLIC_)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Fulfillment (server-only) — order writes + confirmation emails
# SANITY_WRITE_TOKEN is above. EMAIL_API_KEY is a Resend API key (optional).
EMAIL_API_KEY=

# Live-show ticketing (server-only) — QR pass + door check-in
# STAFF_PIN gates check-in and the /attendees page. HUBSPOT_TOKEN is a HubSpot
# private-app token (scope crm.objects.contacts.write) for attendee sync.
STAFF_PIN=
HUBSPOT_TOKEN=

# Cloudflare R2 base URL for video assets
PUBLIC_R2_VIDEO_BASE=
