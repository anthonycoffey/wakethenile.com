{
  // Cloudflare Pages configuration. Applies to both the Git-connected build
  // and `wrangler pages deploy dist`. The nodejs_compat flag is required by
  // the @astrojs/cloudflare adapter so the commerce worker routes (Stripe +
  // Sanity SDKs) run — without it, /api/* and /checkout/return error at runtime.
  "name": "wakethenile",
  "compatibility_date": "2025-06-01",
  "compatibility_flags": ["nodejs_compat"],
  "pages_build_output_dir": "./dist"
}
