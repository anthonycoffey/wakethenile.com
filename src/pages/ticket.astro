---
import BaseLayout from '../layouts/BaseLayout.astro';
import TicketView from '../components/TicketView.tsx';
---

<BaseLayout title="Your Ticket" description="Your Wake the Nile show ticket." footer="scroll">
  <section class="ticketpage">
    <TicketView client:load />
  </section>
</BaseLayout>

<style>
  .ticketpage {
    max-width: 460px;
    margin-inline: auto;
    padding: calc(9vh + 4.5rem) 1.25rem 5rem;
    text-align: center;
  }

  .ticketpage :global(.ticket) {
    background: #0d0d0d;
    border: 1px solid color-mix(in srgb, var(--accent) 30%, transparent);
    border-radius: var(--radius);
    padding: 2rem 1.5rem 2.25rem;
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .ticketpage :global(.ticket--vip) {
    border-color: var(--accent);
    box-shadow: 0 0 0 1px var(--accent), 0 20px 50px rgba(0, 0, 0, 0.5);
  }

  .ticketpage :global(.ticket__badge) {
    display: inline-block;
    background: color-mix(in srgb, var(--accent) 18%, transparent);
    color: var(--accent);
    border: 1px solid var(--accent);
    font-size: 0.7rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    padding: 0.35em 0.9em;
    border-radius: 100px;
    margin-bottom: 1rem;
  }
  .ticketpage :global(.ticket__badge--vip) {
    background: var(--accent);
    color: var(--accent-ink);
  }

  .ticketpage :global(.ticket__title) {
    color: var(--accent);
    font-size: 1.6rem;
    margin: 0 0 0.25rem;
  }
  .ticketpage :global(.ticket__venue) {
    color: var(--muted);
    font-size: 0.9rem;
    margin: 0 0 1rem;
  }
  .ticketpage :global(.ticket__name) {
    color: var(--accent);
    font-size: 1.15rem;
    font-weight: 700;
    margin: 0 0 0.25rem;
  }
  .ticketpage :global(.ticket__admits) {
    color: var(--muted);
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 1px;
    margin: 0 0 1.5rem;
  }

  .ticketpage :global(.ticket__qr) {
    width: min(260px, 72vw);
    aspect-ratio: 1 / 1;
    background: #fff;
    padding: 12px;
    border-radius: 10px;
  }
  .ticketpage :global(.ticket__qr svg) {
    width: 100%;
    height: 100%;
    display: block;
  }
  .ticketpage :global(.ticket__hint) {
    color: var(--muted);
    font-size: 0.8rem;
    margin: 0.75rem 0 1.25rem;
  }

  .ticketpage :global(.ticket__status) {
    font-size: 0.85rem;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 1px;
    margin: 0 0 0.5rem;
  }
  .ticketpage :global(.ticket__status--in) {
    color: #46c26a;
    font-weight: 700;
  }

  .ticketpage :global(.ticket__staff) {
    margin-top: 1.25rem;
    width: 100%;
  }
  .ticketpage :global(.ticket__checkin) {
    width: 100%;
    max-width: 20rem;
    padding: 0.9rem 1.4rem;
    background: var(--accent);
    color: var(--accent-ink);
    border: 2px solid var(--accent);
    border-radius: 100px;
    font-family: inherit;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 1px;
    cursor: pointer;
  }
  .ticketpage :global(.ticket__checkin:disabled) {
    opacity: 0.5;
    cursor: not-allowed;
  }
  .ticketpage :global(.ticket__checkinmsg) {
    margin-top: 0.75rem;
    color: var(--accent);
    font-size: 0.9rem;
  }
  .ticketpage :global(.ticket__stafflink) {
    background: none;
    border: none;
    color: var(--muted);
    font-family: inherit;
    font-size: 0.75rem;
    text-decoration: underline;
    cursor: pointer;
    opacity: 0.6;
  }
  .ticketpage :global(.ticket__lead) {
    color: var(--accent);
  }
</style>
