---
import BaseLayout from '../layouts/BaseLayout.astro';
import ShopBrowser from '../components/ShopBrowser.tsx';
import type { BrowserProduct } from '../components/ShopBrowser.tsx';
import { sanityFetch } from '../lib/sanity';
import { allProductsQuery } from '../lib/queries';
import { urlForWidth } from '../lib/sanityImage';
import type { ProductCardData } from '../lib/types';

const products = await sanityFetch<ProductCardData[]>(allProductsQuery, {}, []);

// Resolve image URLs server-side (the hydrated island has no Sanity creds).
const items: BrowserProduct[] = products.map((p) => ({
  id: p._id,
  slug: p.slug ?? '',
  title: p.title ?? '',
  image: urlForWidth(p.images?.[0], 800) ?? undefined,
  fromPrice: p.fromPrice,
  inStock: p.inStock !== false,
  category: p.category,
  tags: p.tags,
}));
const count = products.length;
---

<BaseLayout title="Shop" description="Official Wake the Nile merch." footer="scroll">
  <section class="shop">
    <header class="shop__head">
      <h1 class="shop__title">Shop</h1>
      <p class="shop__sub">{count > 0 ? `${count} item${count === 1 ? '' : 's'}` : 'Official merch'}</p>
    </header>
    <ShopBrowser client:load products={items} />
  </section>
</BaseLayout>

<style>
  .shop {
    max-width: 1200px;
    margin-inline: auto;
    padding: calc(8vh + 4.5rem) 1.5rem 6rem;
  }
  .shop__head {
    text-align: center;
    margin-bottom: 3rem;
  }
  /* Consistent with the Connect/Shows page titles. */
  .shop__title {
    color: var(--accent);
    font-size: clamp(3.5rem, 3rem + 4vw, 5.5rem);
    letter-spacing: -0.02em;
  }
  .shop__sub {
    margin: 0.6rem 0 0;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 2px;
    font-size: 0.8rem;
  }
</style>
