---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProductPurchase from '../../components/ProductPurchase.tsx';
import type { PurchaseVariant } from '../../components/ProductPurchase.tsx';
import { sanityFetch } from '../../lib/sanity';
import { allProductSlugsQuery, productBySlugQuery } from '../../lib/queries';
import { urlForWidth } from '../../lib/sanityImage';
import { renderPortableText } from '../../lib/portableText';
import type { Product } from '../../lib/types';

export async function getStaticPaths() {
  const slugs = await sanityFetch<{ slug: string }[]>(allProductSlugsQuery, {}, []);
  return slugs.filter((s) => s.slug).map((s) => ({ params: { slug: s.slug } }));
}

const { slug } = Astro.params;
const product = await sanityFetch<Product | null>(productBySlugQuery, { slug }, null);

if (!product) {
  return Astro.redirect('/merch');
}

const gallery = (product.images ?? [])
  .map((img) => urlForWidth(img, 1000))
  .filter((u): u is string => !!u);

const variants: PurchaseVariant[] = (product.variants ?? []).map((v) => ({
  label: v.label ?? '',
  sku: v.sku ?? '',
  price: typeof v.price === 'number' ? v.price : (product.price ?? 0),
  stock: typeof v.stock === 'number' ? v.stock : 0,
}));

const descriptionHtml = renderPortableText(product.description);
---

<BaseLayout title={product.title} seo={product.seo} footer="scroll">
  <section class="pdp">
    <a class="pdp__back" href="/merch">← Back to Merch</a>

    <div class="pdp__grid">
      <div class="pdp__gallery">
        {gallery.length > 0 ? (
          <>
            <img class="pdp__main" src={gallery[0]} alt={product.title} loading="eager" />
            {gallery.length > 1 && (
              <div class="pdp__thumbs">
                {gallery.slice(1).map((src, i) => (
                  <img class="pdp__thumb" src={src} alt={`${product.title} ${i + 2}`} loading="lazy" />
                ))}
              </div>
            )}
          </>
        ) : (
          <span class="pdp__placeholder" aria-hidden="true" />
        )}
      </div>

      <div class="pdp__info">
        <h1 class="pdp__title">{product.title}</h1>

        <ProductPurchase
          client:load
          productId={product._id}
          slug={product.slug ?? ''}
          title={product.title ?? ''}
          image={gallery[0]}
          basePrice={product.price}
          variants={variants}
        />

        {descriptionHtml && (
          <div class="pdp__desc" set:html={descriptionHtml} />
        )}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .pdp {
    max-width: 1100px;
    margin-inline: auto;
    padding: calc(7vh + 4.5rem) 1.5rem 6rem;
  }
  .pdp__back {
    display: inline-block;
    color: var(--muted);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 2px;
    margin-bottom: 2rem;
  }
  .pdp__back:hover {
    color: var(--accent);
  }
  .pdp__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3.5rem;
    align-items: start;
  }
  .pdp__gallery {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .pdp__main,
  .pdp__placeholder {
    width: 100%;
    aspect-ratio: 4 / 5;
    object-fit: cover;
    background: #111;
  }
  .pdp__placeholder {
    background: repeating-linear-gradient(
      45deg, #141414, #141414 14px, #1a1a1a 14px, #1a1a1a 28px
    );
  }
  .pdp__thumbs {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0.75rem;
  }
  .pdp__thumb {
    width: 100%;
    aspect-ratio: 1 / 1;
    object-fit: cover;
    background: #111;
    cursor: pointer;
  }
  .pdp__info {
    position: sticky;
    top: 6.5rem;
  }
  .pdp__title {
    color: var(--accent);
    font-size: clamp(1.9rem, 1.5rem + 2vw, 2.75rem);
    letter-spacing: -0.02em;
    margin-bottom: 1.5rem;
  }
  .pdp__desc {
    margin-top: 2rem;
    padding-top: 2rem;
    border-top: 1px solid color-mix(in srgb, var(--accent) 22%, transparent);
    color: var(--muted);
    line-height: 1.7;
  }
  .pdp__desc :global(a) {
    color: var(--accent);
    text-decoration: underline;
  }
  @media (max-width: 760px) {
    .pdp__grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
    .pdp__info {
      position: static;
    }
  }
</style>

<style is:global>
  /* React-island purchase widget — standard e-commerce controls, gold brand. */
  .purchase {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    align-items: flex-start;
  }
  .purchase__price {
    color: var(--accent);
    font-size: 1.8rem;
    font-weight: 700;
    margin: 0;
  }
  .purchase__label {
    display: block;
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: var(--muted);
    margin-bottom: 0.6rem;
  }
  .purchase__sizes {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
  }
  .purchase__size {
    min-width: 3rem;
    padding: 0.6rem 0.9rem;
    background: transparent;
    color: var(--accent);
    border: 1px solid color-mix(in srgb, var(--accent) 55%, transparent);
    font-family: inherit;
    font-size: 0.95rem;
    font-weight: 600;
    cursor: pointer;
    transition: background-color 0.2s ease, color 0.2s ease, border-color 0.2s ease;
  }
  .purchase__size:hover:not(:disabled) {
    border-color: var(--accent);
  }
  .purchase__size[aria-pressed='true'] {
    background: var(--accent);
    color: var(--accent-ink);
    border-color: var(--accent);
  }
  .purchase__size:disabled {
    opacity: 0.35;
    cursor: not-allowed;
    text-decoration: line-through;
  }
  .purchase__qtyrow {
    display: flex;
    align-items: center;
    gap: 0;
  }
  .purchase__qtybtn {
    width: 2.6rem;
    height: 2.6rem;
    background: transparent;
    color: var(--accent);
    border: 1px solid color-mix(in srgb, var(--accent) 55%, transparent);
    font-size: 1.2rem;
    cursor: pointer;
    line-height: 1;
  }
  .purchase__qtybtn:disabled {
    opacity: 0.35;
    cursor: not-allowed;
  }
  .purchase__qtyval {
    min-width: 3rem;
    height: 2.6rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-top: 1px solid color-mix(in srgb, var(--accent) 55%, transparent);
    border-bottom: 1px solid color-mix(in srgb, var(--accent) 55%, transparent);
    color: var(--accent);
    font-weight: 700;
  }
  /* Primary "add to cart" — filled gold, inverts on hover (standard CTA). */
  .purchase__add {
    width: 100%;
    max-width: 22rem;
    padding: 0.95rem 1.5rem;
    background: var(--accent);
    color: var(--accent-ink);
    border: 2px solid var(--accent);
    border-radius: 100px;
    text-transform: uppercase;
    font-weight: 800;
    letter-spacing: 1px;
    font-size: 1rem;
    cursor: pointer;
    transition: background-color 0.25s ease, color 0.25s ease;
  }
  .purchase__add:hover:not(:disabled) {
    background: transparent;
    color: var(--accent);
  }
  .purchase__add:disabled {
    opacity: 0.45;
    cursor: not-allowed;
  }
  .purchase__note {
    margin: 0;
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: var(--muted);
  }
  .purchase__view {
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 2px;
    text-decoration: underline;
    color: var(--accent);
  }
</style>
