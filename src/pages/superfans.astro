---
// wakethenile.com/superfans
// Presale landing page for our first live show. Sales are temporarily paused
// (venue + one supporting act fell through) — see
// docs/specs/active/pause-ticket-sales.md. The Live Show Ticket and VIP Fan
// Experience products are tagged `hidden` + stock 0 in Sanity so they can't
// be bought anywhere on the site while this holding message is up. To
// resume: un-hide + restock those two products, and restore the purchase
// cards this file used to render (see git history on this file).
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Superfan Presale"
  description="Details for our first live show are being finalized — check back soon."
  footer="scroll"
>
  <section class="superfans">
    <p class="superfans__eyebrow">Our First Live Show</p>
    <h1 class="superfans__title">Details Coming Soon</h1>
    <p class="superfans__sub">
      We're finalizing the venue and lineup for our first live show. Ticket sales are paused in the
      meantime — check back here soon for the updated date, venue, and how to grab a ticket.
    </p>
  </section>
</BaseLayout>

<style>
  .superfans {
    max-width: 640px;
    margin-inline: auto;
    padding: calc(8vh + 4.5rem) 1.5rem 8rem;
    text-align: center;
  }
  .superfans__eyebrow {
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 3px;
    font-size: 0.8rem;
    font-weight: 700;
    margin: 0 0 0.5rem;
  }
  .superfans__title {
    color: var(--accent);
    font-size: clamp(2.25rem, 2rem + 3vw, 3.75rem);
    letter-spacing: -0.02em;
    margin: 0 0 1rem;
  }
  .superfans__sub {
    color: var(--muted);
    max-width: 46ch;
    margin: 0 auto;
    font-size: 1rem;
    line-height: 1.6;
  }
</style>
