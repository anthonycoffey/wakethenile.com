---
// New page: wakethenile.com/superfans
// Presale landing page for the first live show (Sep 19 @ Maggie Mae's Upstairs).
// Two options: the Mega Superfan Bundle (ticket + merch bundle + VIP) or a
// standalone ticket.
//  - Bundle: adds to cart and goes straight to /checkout (no merch browsing).
//  - Ticket only: adds to cart and goes to /merch, with a temporary banner
//    inviting them to grab anything else before checking out.
import BaseLayout from '../layouts/BaseLayout.astro';
import { sanityFetch } from '../lib/sanity';
import { urlForWidth } from '../lib/sanityImage';
import { bundleOptionGroupsFor } from '../lib/bundleOptions';

interface ProductImg {
  id: string;
  images?: unknown[];
}

// Product IDs + cart line data. These match the products created in Sanity;
// if you ever recreate these products, update the IDs here to match. We look
// products up by _id (not slug) so a rename in the CMS can't break the page —
// the bundle was previously slug "mega-superfan-bundle" and got renamed.
const BUNDLE_PRODUCT_ID = 'b351d11f-4c78-4a1f-b36b-c10d951c96ea';
const TICKET_PRODUCT_ID = '2480f00d-9317-4ed0-9406-bcef1e34bc71';

const query = `*[_type == "product" && _id in [$bundleId, $ticketId]]{
  "id": _id, images
}`;
const products = await sanityFetch<ProductImg[]>(
  query,
  { bundleId: BUNDLE_PRODUCT_ID, ticketId: TICKET_PRODUCT_ID },
  [],
);
const bundle = products.find((p) => p.id === BUNDLE_PRODUCT_ID);
const ticket = products.find((p) => p.id === TICKET_PRODUCT_ID);

const bundleImg = urlForWidth(bundle?.images?.[0], 900);
const posterImg = urlForWidth(ticket?.images?.[0], 900);

// Tee/size the customer must pick with the bundle (shared with /merch + the
// checkout validator). See ADR 0007 / src/lib/bundleOptions.ts.
const bundleOptionGroups = bundleOptionGroupsFor(BUNDLE_PRODUCT_ID) ?? [];
---

<BaseLayout
  title="Superfan Presale"
  description="Get tickets to our first live show — September 19th at Maggie Mae's Upstairs."
  footer="scroll"
>
  <section class="superfans">
    <p class="superfans__eyebrow">Our First Live Show</p>
    <h1 class="superfans__title">September 19 — Maggie Mae's Upstairs</h1>
    <p class="superfans__sub">Pick your option below. The first 100 tickets are $25 — price rises to $35 after that.</p>
    <p class="superfans__note">Any merch you get with either option can be picked up at our Merch booth on show night — no shipping wait.</p>

    <div class="superfans__cards">
      <div class="superfans__card superfans__card--bundle">
        <span class="superfans__imgstack">
          {posterImg && <img src={posterImg} alt="Album Release Show Poster" class="superfans__img superfans__img--back" />}
          {bundleImg && <img src={bundleImg} alt="Ultimate Fan Merch Bundle" class="superfans__img superfans__img--front" />}
        </span>
        <h2 class="superfans__name">Mega Superfan Bundle</h2>
        <p class="superfans__price">$100</p>
        <p class="superfans__desc">Show ticket + Ultimate Fan Merch Bundle + VIP area access</p>

        <div class="superfans__options">
          {bundleOptionGroups.map((group) => (
            <div class="superfans__optgroup" data-group={group.name}>
              <span class="superfans__optlabel">{group.name}</span>
              <div class="superfans__opts">
                {group.values.map((value) => (
                  <button type="button" class="superfans__opt" data-value={value} aria-pressed="false">
                    {value}
                  </button>
                ))}
              </div>
            </div>
          ))}
        </div>

        <button type="button" class="superfans__cta superfans__cta--btn" data-bundle-add disabled>
          Select tee &amp; size
        </button>
      </div>

      <button type="button" class="superfans__card" data-product="ticket">
        <span class="superfans__imgstack superfans__imgstack--single">
          {posterImg && <img src={posterImg} alt="Album Release Show Poster" class="superfans__img" />}
        </span>
        <h2 class="superfans__name">Live Show Ticket</h2>
        <p class="superfans__price">$25</p>
        <p class="superfans__desc">General admission to the show</p>
        <span class="superfans__cta">Add to Cart →</span>
      </button>
    </div>
  </section>
</BaseLayout>

<script>
  import { addItem } from '../lib/cart';

  const BUNDLE_PRODUCT_ID = 'b351d11f-4c78-4a1f-b36b-c10d951c96ea';
  const TICKET_PRODUCT_ID = '2480f00d-9317-4ed0-9406-bcef1e34bc71';

  const cardImage = (root: Element): string | undefined => {
    const imgs = root.querySelectorAll('img');
    return imgs[imgs.length - 1]?.getAttribute('src') ?? undefined;
  };

  // Ticket card — a plain whole-card button: click adds and nudges to merch.
  const ticketCard = document.querySelector<HTMLButtonElement>('[data-product="ticket"]');
  ticketCard?.addEventListener('click', () => {
    addItem({
      productId: TICKET_PRODUCT_ID,
      slug: 'live-show-ticket',
      title: 'Live Show Ticket',
      sku: 'TICKET-EARLYBIRD',
      variantLabel: 'Early Bird (First 100)',
      unitPrice: 25,
      qty: 1,
      image: cardImage(ticketCard),
    });
    sessionStorage.setItem('wtn_upsell_msg', '1');
    window.location.href = '/merch';
  });

  // Bundle card — the tee + size must be chosen before the CTA unlocks.
  const bundleCard = document.querySelector<HTMLElement>('.superfans__card--bundle');
  if (bundleCard) {
    const addBtn = bundleCard.querySelector<HTMLButtonElement>('[data-bundle-add]');
    const groups = [...bundleCard.querySelectorAll<HTMLElement>('.superfans__optgroup')];
    const choices: Record<string, string> = {};

    const groupName = (g: HTMLElement) => g.dataset.group ?? '';
    const allChosen = () => groups.every((g) => choices[groupName(g)]);

    const refresh = () => {
      if (!addBtn) return;
      const ready = allChosen();
      addBtn.disabled = !ready;
      addBtn.textContent = ready ? 'Add to Cart →' : 'Select tee & size';
    };

    for (const g of groups) {
      const name = groupName(g);
      const opts = [...g.querySelectorAll<HTMLButtonElement>('.superfans__opt')];
      for (const btn of opts) {
        btn.addEventListener('click', () => {
          choices[name] = btn.dataset.value ?? '';
          for (const b of opts) b.setAttribute('aria-pressed', String(b === btn));
          refresh();
        });
      }
    }

    addBtn?.addEventListener('click', () => {
      if (!allChosen()) return;
      const options = groups.map((g) => ({ name: groupName(g), value: choices[groupName(g)] }));
      addItem({
        productId: BUNDLE_PRODUCT_ID,
        slug: 'mega-superfan-bundle',
        title: 'Mega Superfan Bundle',
        sku: 'mega-superfan-bundle',
        unitPrice: 100,
        qty: 1,
        image: cardImage(bundleCard),
        options,
      });
      // Bundle buyers skip merch browsing entirely — straight to checkout.
      window.location.href = '/checkout';
    });
  }
</script>

<style>
  .superfans {
    max-width: 1100px;
    margin-inline: auto;
    padding: calc(8vh + 4.5rem) 1.5rem 2rem;
    text-align: center;
  }
  .superfans__eyebrow {
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 3px;
    font-size: 0.8rem;
    font-weight: 700;
    margin: 0 0 0.5rem;
  }
  .superfans__title {
    color: var(--accent);
    font-size: clamp(2.25rem, 2rem + 3vw, 3.75rem);
    letter-spacing: -0.02em;
    margin: 0 0 0.75rem;
  }
  .superfans__sub {
    color: var(--muted);
    max-width: 46ch;
    margin: 0 auto 0.75rem;
    font-size: 0.95rem;
  }
  .superfans__note {
    color: var(--accent);
    opacity: 0.85;
    max-width: 46ch;
    margin: 0 auto 3.5rem;
    font-size: 0.82rem;
  }

  /* Cards float below the main content and slightly overlap the footer. */
  .superfans__cards {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
    margin-bottom: -70px;
    position: relative;
    z-index: 2;
  }
  @media (max-width: 720px) {
    .superfans__cards {
      grid-template-columns: 1fr;
      margin-bottom: -40px;
    }
  }

  .superfans__card {
    display: flex;
    flex-direction: column;
    align-items: center;
    background: #0d0d0d;
    border: 1px solid color-mix(in srgb, var(--accent) 25%, transparent);
    border-radius: var(--radius);
    padding: 2rem 1.5rem 2.25rem;
    cursor: pointer;
    font-family: inherit;
    color: var(--accent);
    transition: transform 0.25s ease, border-color 0.25s ease, box-shadow 0.25s ease;
  }
  .superfans__card:hover,
  .superfans__card:focus-visible {
    transform: translateY(-10px) scale(1.03);
    border-color: var(--accent);
    box-shadow: 0 20px 45px rgba(0, 0, 0, 0.55);
    outline: none;
  }

  .superfans__imgstack {
    position: relative;
    width: 100%;
    max-width: 320px;
    aspect-ratio: 4 / 5;
    margin-bottom: 1.5rem;
  }
  .superfans__img {
    position: absolute;
    width: 60%;
    height: 60%;
    object-fit: cover;
    border-radius: calc(var(--radius) - 2px);
    box-shadow: 0 12px 30px rgba(0, 0, 0, 0.5);
  }
  /* Bundle card: show poster behind (top-left), merch bundle in front
     (bottom-right) — sized down with more room between them so they read as
     two distinct items rather than a single stacked image. */
  .superfans__img--back {
    top: 0;
    left: 0;
  }
  .superfans__img--front {
    bottom: 0;
    right: 0;
    border: 3px solid var(--bg);
  }
  .superfans__imgstack--single .superfans__img {
    position: static;
    width: 100%;
    height: 100%;
  }

  .superfans__name {
    font-size: 1.15rem;
    text-transform: uppercase;
    letter-spacing: 0.02em;
    margin: 0 0 0.4rem;
  }
  .superfans__price {
    font-size: 1.75rem;
    font-weight: 800;
    margin: 0 0 0.6rem;
  }
  .superfans__desc {
    color: var(--muted);
    font-size: 0.85rem;
    max-width: 30ch;
    margin: 0 0 1.5rem;
  }
  .superfans__cta {
    display: inline-block;
    border: 2px solid var(--accent);
    color: var(--accent);
    border-radius: 100px;
    text-transform: uppercase;
    font-weight: 800;
    font-size: 0.85rem;
    letter-spacing: 1px;
    padding: 0.6em 1.4em;
    transition: background-color 0.25s ease, color 0.25s ease;
  }
  /* Only the plain (ticket) card fills its CTA on hover. The bundle CTA is a
     real button with its own hover/disabled states below. */
  .superfans__card:not(.superfans__card--bundle):hover .superfans__cta {
    background: var(--accent);
    color: var(--accent-ink);
  }

  /* The bundle card is a container (not a single click target) — its own
     controls handle clicks, so don't imply the whole card is clickable. */
  .superfans__card--bundle {
    cursor: default;
  }

  /* Bundle tee/size selectors. */
  .superfans__options {
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-bottom: 1.5rem;
    text-align: left;
  }
  .superfans__optlabel {
    display: block;
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: var(--muted);
    margin-bottom: 0.5rem;
  }
  .superfans__opts {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  .superfans__opt {
    min-width: 2.8rem;
    padding: 0.5rem 0.85rem;
    background: transparent;
    color: var(--accent);
    border: 1px solid color-mix(in srgb, var(--accent) 45%, transparent);
    border-radius: 6px;
    font-family: inherit;
    font-size: 0.9rem;
    font-weight: 600;
    cursor: pointer;
    transition: background-color 0.2s ease, color 0.2s ease, border-color 0.2s ease;
  }
  .superfans__opt:hover {
    border-color: var(--accent);
  }
  .superfans__opt[aria-pressed='true'] {
    background: var(--accent);
    color: var(--accent-ink);
    border-color: var(--accent);
  }

  /* CTA rendered as a <button> on the bundle card. */
  .superfans__cta--btn {
    background: transparent;
    font-family: inherit;
    cursor: pointer;
  }
  .superfans__cta--btn:not(:disabled):hover {
    background: var(--accent);
    color: var(--accent-ink);
  }
  .superfans__cta--btn:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }
</style>
