---
// wakethenile.com/music — cover hero (CMS-driven, same as the old generic
// template) plus a static track list with inline players. Drifting Away has
// no player yet (unreleased) — its row is an "Early Access" CTA to /drifting
// instead. Audio/cover assets are static files, not CMS-managed, matching how
// /videos coverflow entries and /drifting already host their media.
import BaseLayout from '../layouts/BaseLayout.astro';
import { sanityFetch } from '../lib/sanity';
import { pageBySlugQuery } from '../lib/queries';
import { urlFor } from '../lib/sanityImage';
import type { Page } from '../lib/types';

const page = await sanityFetch<Page | null>(pageBySlugQuery, { slug: 'music' }, null);

const bg = page?.coverImage ? urlFor(page.coverImage) : undefined;
const ov = page?.overlay;
const overlayOn = ov?.enabled !== false && !!ov?.color;
const overlayColor = ov?.color ?? '#000000';
const overlayOpacity = typeof ov?.opacity === 'number' ? ov.opacity : 0.2;

interface Track {
  title: string;
  cover: string;
  audio?: string;
  earlyAccessHref?: string;
}

const tracks: Track[] = [
  { title: 'Lamb', cover: '/images/lamb-cover.jpg', audio: '/audio/lamb.mp3' },
  { title: 'Mercy', cover: '/images/mercy-cover.jpg', audio: '/audio/mercy.mp3' },
  { title: 'Champion', cover: '/images/champion-cover.jpg', audio: '/audio/champion.mp3' },
  { title: 'Drifting Away', cover: '/images/drifting-away-cover.jpg', earlyAccessHref: '/drifting' },
];
---

<BaseLayout title="Music" description="Listen to music from Wake the Nile." footer="scroll">
  <section class="music" style={bg ? `--cover-bg: url('${bg}')` : undefined}>
    {bg && <div class="music__bg" />}
    {bg && overlayOn && (
      <div class="music__overlay" style={`background:${overlayColor}; opacity:${overlayOpacity}`} />
    )}
    <div class="music__content">
      <h1 class="music__title">Music</h1>

      <ul class="tracklist">
        {tracks.map((track) => (
          <li class="track">
            <img class="track__cover" src={track.cover} alt={`${track.title} cover art`} width="120" height="120" loading="lazy" />
            <div class="track__body">
              <p class="track__title">{track.title}</p>
              {track.audio ? (
                <audio class="track__audio" controls preload="none" src={track.audio}>
                  Your browser doesn't support inline audio.
                </audio>
              ) : (
                <a class="btn track__cta" href={track.earlyAccessHref}>Early Access</a>
              )}
            </div>
          </li>
        ))}
      </ul>
    </div>
  </section>
</BaseLayout>

<style>
  .music {
    position: relative;
    padding-bottom: 4rem;
  }
  .music__bg {
    position: absolute;
    inset: 0;
    height: 60vh;
    background-image: var(--cover-bg);
    background-size: cover;
    background-position: center top;
    z-index: 0;
  }
  .music__overlay {
    position: absolute;
    inset: 0;
    height: 60vh;
    z-index: 1;
  }
  .music__content {
    position: relative;
    z-index: 2;
    max-width: 720px;
    margin-inline: auto;
    padding: calc(14vh + 2rem) 1.25rem 2rem;
    text-align: center;
  }
  .music__title {
    color: var(--accent);
    font-weight: 700;
    text-transform: uppercase;
    line-height: 1;
    font-size: clamp(3rem, 2.5rem + 3vw, 4.5rem);
    margin: 0 0 3rem;
  }

  .tracklist {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    text-align: left;
  }
  .track {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    background: rgba(13, 13, 13, 0.75);
    border: 1px solid color-mix(in srgb, var(--accent) 25%, transparent);
    border-radius: var(--radius);
    padding: 1rem;
    backdrop-filter: blur(4px);
  }
  .track__cover {
    width: 84px;
    height: 84px;
    border-radius: calc(var(--radius) - 2px);
    object-fit: cover;
    flex-shrink: 0;
  }
  .track__body {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .track__title {
    color: var(--accent);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.02em;
    margin: 0;
  }
  .track__audio {
    width: 100%;
    height: 32px;
  }
  .track__cta {
    align-self: flex-start;
    font-size: 0.85rem;
    padding: 0.55em 1.2em;
  }

  @media (max-width: 520px) {
    .track {
      gap: 0.85rem;
      padding: 0.85rem;
    }
    .track__cover {
      width: 64px;
      height: 64px;
    }
  }
</style>
