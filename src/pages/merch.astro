---
import BaseLayout from '../layouts/BaseLayout.astro';
import ShopBrowser from '../components/ShopBrowser.tsx';
import type { BrowserProduct } from '../components/ShopBrowser.tsx';
import StoreClosed from '../components/StoreClosed.astro';
import { sanityFetch } from '../lib/sanity';
import { allProductsQuery } from '../lib/queries';
import { urlForWidth } from '../lib/sanityImage';
import { getStoreStatus } from '../lib/store';
import type { ProductCardData } from '../lib/types';

const { open, settings } = await getStoreStatus();

// Resolve image URLs server-side (the hydrated island has no Sanity creds).
let items: BrowserProduct[] = [];
if (open) {
  const products = await sanityFetch<ProductCardData[]>(allProductsQuery, {}, []);
  items = products.map((p) => ({
    id: p._id,
    slug: p.slug ?? '',
    title: p.title ?? '',
    image: urlForWidth(p.images?.[0], 800) ?? undefined,
    fromPrice: p.fromPrice,
    inStock: p.inStock !== false,
    category: p.category,
    tags: p.tags,
  }));
}
---

<BaseLayout title={open ? 'Merch' : 'Shop'} description="Official Wake the Nile merch." footer="scroll">
  {open ? (
    <section class="merch">
      <div id="upsell-toast" class="upsell-toast" hidden>
        Ticket added to your cart — want to grab anything else before you check out?
      </div>
      <h1 class="merch__title">Merch</h1>
      <ShopBrowser client:load products={items} />
    </section>
  ) : (
    <StoreClosed settings={settings} />
  )}
</BaseLayout>

<script>
  // Set by the /superfans landing page after a ticket-only purchase.
  const KEY = 'wtn_upsell_msg';
  if (sessionStorage.getItem(KEY)) {
    sessionStorage.removeItem(KEY);
    const el = document.getElementById('upsell-toast');
    if (el) {
      el.hidden = false;
      window.setTimeout(() => {
        el.hidden = true;
      }, 7000);
    }
  }
</script>

<style>
  .merch {
    max-width: 1200px;
    margin-inline: auto;
    padding: calc(8vh + 4.5rem) 1.5rem 6rem;
  }
  /* Consistent with Connect/Shows titles. Count + filters live in the island
     bar below, so the gap down to the grid is tighter. */
  .merch__title {
    color: var(--accent);
    font-size: clamp(3.5rem, 3rem + 4vw, 5.5rem);
    letter-spacing: -0.02em;
    text-align: center;
    margin-bottom: 1.5rem;
  }

  .upsell-toast {
    max-width: 640px;
    margin: 0 auto 2rem;
    background: color-mix(in srgb, var(--accent) 12%, #0d0d0d);
    border: 1px solid var(--accent);
    border-radius: var(--radius);
    color: var(--accent);
    font-size: 0.85rem;
    text-align: center;
    padding: 0.85rem 1.25rem;
    animation: wtnFadeIn 0.3s ease;
  }
</style>
