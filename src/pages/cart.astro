---
import BaseLayout from '../layouts/BaseLayout.astro';
import CartPage from '../components/CartPage.tsx';
import StoreClosed from '../components/StoreClosed.astro';
import { getStoreStatus } from '../lib/store';

const { open, settings } = await getStoreStatus();
---

<BaseLayout title={open ? 'Cart' : 'Shop'} description="Your Wake the Nile cart." footer="scroll">
  {open ? (
    <section class="cartpage-section">
      <h1 class="cartpage-section__title">Your Cart</h1>
      <CartPage client:load />
    </section>
  ) : (
    <StoreClosed settings={settings} />
  )}
</BaseLayout>

<style>
  .cartpage-section {
    max-width: 1100px;
    margin-inline: auto;
    padding: calc(7vh + 4.5rem) 1.5rem 6rem;
  }
  .cartpage-section__title {
    color: var(--accent);
    font-size: clamp(2.25rem, 1.8rem + 2.5vw, 3.25rem);
    letter-spacing: -0.02em;
    margin-bottom: 2.5rem;
    text-align: center;
  }
</style>
