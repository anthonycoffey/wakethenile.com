---
import BaseLayout from '../layouts/BaseLayout.astro';
import CoverSection from '../components/CoverSection.astro';
import { sanityFetch } from '../lib/sanity';
import { homePageQuery } from '../lib/queries';
import type { Page } from '../lib/types';

const page = await sanityFetch<Page | null>(homePageQuery, {}, null);

// Homepage is the wordmark cover. Fall back to a hardcoded shell if unseeded.
const home: Page = page ?? { isHome: true, overlay: { enabled: true, color: '#000000', opacity: 0.7 } };
---

<BaseLayout title={page?.title ?? 'Wake the Nile'} seo={page?.seo} footer="home">
  <CoverSection page={{ ...home, isHome: true }} />
</BaseLayout>
