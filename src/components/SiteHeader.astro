---
import type { NavItem } from '../lib/types';
import Cart from './Cart.tsx';

interface Props {
  nav?: NavItem[];
}
const { nav = [] } = Astro.props;

const items: NavItem[] =
  nav.length > 0
    ? nav
    : [
        { label: 'Music', href: '/music' },
        { label: 'Videos', href: '/videos' },
        { label: 'Connect', href: '/connect' },
        { label: 'Shows', href: '/shows' },
      ];
---

<header class="site-header">
  <a class="site-header__logo brand-mark" href="/" aria-label="Wake the Nile"></a>

  <nav class="site-header__nav" id="primary-nav">
    {items.map((item) => <a href={item.href}>{item.label}</a>)}
  </nav>

  <div class="site-header__actions">
    <Cart client:load />
    <button
      class="site-header__burger"
      type="button"
      aria-label="Open menu"
      aria-controls="primary-nav"
      aria-expanded="false"
    >
      <span class="site-header__burger-box"><span class="site-header__burger-inner"></span></span>
    </button>
  </div>
</header>

<script is:inline>
  (function () {
    const header = document.querySelector('.site-header');
    const burger = header && header.querySelector('.site-header__burger');
    const nav = document.getElementById('primary-nav');
    if (!header || !burger || !nav) return;
    function setOpen(open) {
      header.classList.toggle('is-nav-open', open);
      burger.setAttribute('aria-expanded', String(open));
      burger.setAttribute('aria-label', open ? 'Close menu' : 'Open menu');
      document.body.style.overflow = open ? 'hidden' : '';
    }
    burger.addEventListener('click', function () {
      setOpen(!header.classList.contains('is-nav-open'));
    });
    nav.addEventListener('click', function (e) {
      if (e.target.closest('a')) setOpen(false);
    });
    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape') setOpen(false);
    });
  })();
</script>

<script is:inline>
  // Dim/hide the nav links (Music/Videos/Connect/Shows) as soon as the page
  // scrolls down at all; only bring them back once scrolled all the way back
  // to the top. The logo and cart/burger stay put the whole time — only
  // .site-header__nav is affected (and only on desktop; see CSS override).
  (function () {
    const header = document.querySelector('.site-header');
    if (!header) return;
    const TOP_THRESHOLD = 12; // px — must be back this close to 0 to reveal
    let ticking = false;

    function update() {
      const y = window.scrollY;
      if (y <= TOP_THRESHOLD) {
        header.classList.remove('site-header--nav-hidden');
      } else {
        header.classList.add('site-header--nav-hidden');
      }
      ticking = false;
    }

    window.addEventListener(
      'scroll',
      function () {
        if (!ticking) {
          window.requestAnimationFrame(update);
          ticking = true;
        }
      },
      { passive: true },
    );
  })();
</script>

<style>
  .site-header {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    z-index: 20;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.4rem;
    padding: 2vh 5vw;
    background: transparent;
    box-sizing: border-box;
  }
  .site-header__logo {
    display: block;
    width: 66px;
    height: 64px;
    -webkit-mask-image: url('/brand/icon.png');
    mask-image: url('/brand/icon.png');
    flex: 0 0 auto;
  }
  .site-header__nav {
    flex: 1;
    display: flex;
    justify-content: flex-end;
    align-items: center;
    gap: 1.4rem;
    transition: opacity 0.35s ease;
  }
  /* Desktop only — dims the inline link bar, leaving logo/cart untouched. */
  .site-header--nav-hidden .site-header__nav {
    opacity: 0;
    pointer-events: none;
  }
  .site-header__nav a {
    color: var(--accent);
    font-family: var(--font-sans);
    font-weight: 700;
    text-transform: uppercase;
    text-decoration: none;
    line-height: 1.2;
    letter-spacing: -0.5px;
    font-size: clamp(1.75rem, 1.7rem + 0.3vw, 2rem);
  }
  .site-header__nav a:hover {
    text-decoration: underline;
    text-decoration-thickness: 0.0625em;
    text-underline-offset: 0.15em;
  }
  .site-header__actions {
    flex: 0 0 auto;
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  /* Hamburger button — hidden on desktop */
  .site-header__burger {
    display: none;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.4rem;
    color: var(--accent);
  }
  .site-header__burger-box {
    display: block;
    width: 30px;
    height: 22px;
    position: relative;
  }
  .site-header__burger-inner,
  .site-header__burger-inner::before,
  .site-header__burger-inner::after {
    content: '';
    position: absolute;
    left: 0;
    width: 30px;
    height: 2.5px;
    background: var(--accent);
    border-radius: 2px;
    transition: transform 0.3s ease, opacity 0.2s ease, background-color 0.2s ease;
  }
  .site-header__burger-inner {
    top: 50%;
    transform: translateY(-50%);
  }
  .site-header__burger-inner::before {
    top: -9px;
  }
  .site-header__burger-inner::after {
    top: 9px;
  }

  @media (max-width: 768px) {
    .site-header__burger {
      display: inline-flex;
    }
    /* Nav becomes a full-screen slide-in menu */
    .site-header__nav {
      position: fixed;
      inset: 0;
      flex: none;
      flex-direction: column;
      justify-content: center;
      gap: 2.25rem;
      background: var(--bg);
      transform: translateX(100%);
      transition: transform 0.32s ease;
      z-index: 30;
    }
    .site-header.is-nav-open .site-header__nav {
      transform: translateX(0);
    }
    .site-header__nav a {
      font-size: clamp(2rem, 1.6rem + 3vw, 2.75rem);
    }
    /* Mobile menu ignores the scroll-hide state entirely — it's only ever
       shown/hidden via the burger toggle (translateX above). */
    .site-header--nav-hidden .site-header__nav {
      opacity: 1;
      pointer-events: auto;
    }
    /* Keep the cart + burger (as the X) tappable above the open menu */
    .site-header__actions {
      z-index: 40;
    }
    /* Burger → X when open */
    .site-header.is-nav-open .site-header__burger-inner {
      background: transparent;
    }
    .site-header.is-nav-open .site-header__burger-inner::before {
      top: 0;
      transform: rotate(45deg);
    }
    .site-header.is-nav-open .site-header__burger-inner::after {
      top: 0;
      transform: rotate(-45deg);
    }
  }
</style>
