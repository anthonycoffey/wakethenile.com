---
import type { CommerceSettings } from '../lib/types';

interface Props {
  /** Commerce settings, used for the editable maintenance heading/message. */
  settings?: CommerceSettings | null;
}

const { settings } = Astro.props;
const heading = settings?.maintenanceHeading?.trim() || 'We’ll be right back';
const message =
  settings?.maintenanceMessage?.trim() ||
  'The shop is closed for maintenance right now. Thanks for your patience — check back soon.';
---

<section class="maintenance">
  <p class="maintenance__eyebrow">Maintenance</p>
  <h1 class="maintenance__heading">{heading}</h1>
  <p class="maintenance__message">{message}</p>
  <a class="maintenance__home" href="/">Back to home</a>
</section>

<style>
  .maintenance {
    max-width: 640px;
    margin-inline: auto;
    padding: calc(12vh + 4.5rem) 1.5rem 8rem;
    text-align: center;
  }
  .maintenance__eyebrow {
    color: var(--accent);
    text-transform: uppercase;
    letter-spacing: 3px;
    font-size: 0.75rem;
    margin: 0 0 1.25rem;
  }
  .maintenance__heading {
    color: var(--accent);
    font-size: clamp(2rem, 1.6rem + 2.5vw, 3.25rem);
    letter-spacing: -0.02em;
    margin: 0 0 1.25rem;
  }
  .maintenance__message {
    color: var(--muted);
    font-size: 1.05rem;
    line-height: 1.6;
    margin: 0 auto 2.5rem;
    max-width: 44ch;
  }
  .maintenance__home {
    display: inline-block;
    padding: 0.85rem 2rem;
    border: 2px solid var(--accent);
    border-radius: 100px;
    color: var(--accent);
    text-transform: uppercase;
    letter-spacing: 1px;
    font-size: 0.8rem;
    font-weight: 700;
    transition: background-color 0.25s ease, color 0.25s ease;
  }
  .maintenance__home:hover {
    background: var(--accent);
    color: var(--accent-ink);
  }
</style>
