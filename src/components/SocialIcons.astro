function norm(p?: string): string {
  return (p ?? '').toLowerCase().replace(/[^a-z]/g, '');
}
const items = socials.filter((s) => s.url && ICONS[norm(s.platform)]);
---

{
  items.length > 0 && (
    <ul class="social-icons" style={`--icon-size:${size}`}>
      {items.map((s) => (
        <li>
          <a href={s.url} target="_blank" rel="noopener" aria-label={s.platform}>
            <svg viewBox="0 0 24 24" role="img" aria-hidden="true">
              <path d={ICONS[norm(s.platform)]} fill="currentColor" />
            </svg>
          </a>
        </li>
      ))}
    </ul>
  )
}

<style>
  .social-icons {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    gap: 1rem;
    justify-content: center;
    align-items: center;
  }
  .social-icons a {
    color: var(--accent);
    display: inline-flex;
  }
  .social-icons svg {
    width: var(--icon-size, 1.25em);
    height: var(--icon-size, 1.25em);
    display: block;
  }
  .social-icons a:hover {
    opacity: 0.8;
  }
</style>
