---
import SocialIcons from './SocialIcons.astro';
import type { SocialLink } from '../lib/types';
interface Props { socials?: SocialLink[]; }
const { socials = [] } = Astro.props;
---

<section class="footer-fixed">
  <a href="/" class="footer-fixed__mark brand-mark" aria-label="Wake the Nile"></a>
  <p class="footer-fixed__label">Follow Us on Social Media</p>
  <SocialIcons socials={socials} size="1.25em" />
</section>

<style>
  .footer-fixed {
    position: fixed;
    bottom: 2%;
    left: 0;
    width: 100%;
    z-index: 5;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.6rem;
    animation: wtnFadeIn 2.5s ease-in-out forwards;
  }
  .footer-fixed__mark {
    width: 290px;
    max-width: 70vw;
    height: 74px;
    -webkit-mask-image: url('/brand/wordmark.png');
    mask-image: url('/brand/wordmark.png');
  }
  .footer-fixed__label {
    margin: 0;
    font-size: 0.8rem;
    font-weight: 100;
    letter-spacing: 1px;
    line-height: 1;
    text-transform: uppercase;
    color: var(--accent);
  }
</style>
